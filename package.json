{
  "name": "riverbucket",
  "version": "0.2.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && tsc -p tsconfig.worker.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.worker.json --noEmit",
    "password:hash": "node scripts/hash-password.mjs",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply riverbucketdb --local",
    "db:migrate:remote": "wrangler d1 migrations apply riverbucketdb --remote",
    "test": "vitest run"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/zilla-slab": "^5.2.8",
    "@vitejs/plugin-react": "^5.0.0",
    "fast-xml-parser": "^5.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260531.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
